# ---------------------------------------------------------------------------
# Documentation / handoff (NOT tracked — internal notes, handoff files, specs)
# ---------------------------------------------------------------------------
docs/

# ---------------------------------------------------------------------------
# Secrets & sanitization (public repo — never commit these)
# Each subproject .gitignore duplicates this privacy block on purpose:
# belt and suspenders. Keep them in sync when editing here.
# ---------------------------------------------------------------------------
# Environment / config — ALL env files are ignored; only *.example templates are tracked
*.env
*.env.*
!*.env.example
*.local

# Private keys, mnemonics, wallets, keystores
*.pem
*.key
*.keystore
*.p12
*.pfx
*.pw
key/
keys/
keystore/
keystores/
wallets/
*mnemonic*
*seed-phrase*
*private-key*
*privatekey*
secrets/
.secret
.secrets
.foundry/

# Cloud / API credentials
.aws/
credentials.json
service-account*.json

# Bead photos never touch git (EXIF = location leak) — all image formats banned
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.heic
*.heif
*.avif
*.raw
*.dng

# ---------------------------------------------------------------------------
# Dependencies & build output (add/remove per chosen stack)
# ---------------------------------------------------------------------------
node_modules/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
venv/
.venv/
dist/
build/
out/
coverage/
cache/
artifacts/
typechain/
typechain-types/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# AI tooling / agent artifacts (internal — never publish)
# ---------------------------------------------------------------------------
superpowers/
.superpowers/
.claude/
CLAUDE.md
AGENTS.md

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Whitepaper build output
whitepaper/out/
