# ---------------------------------------------------------------------------
# Privacy boundary (duplicated in every subproject .gitignore on purpose;
# the root .gitignore carries the same net — belt and suspenders)
# ---------------------------------------------------------------------------
# Environment / config — ALL env files ignored; only *.example templates tracked
# (HMAC_SECRET and any backend credentials live in env files — never in git)
*.env
*.env.*
!*.env.example
*.local

# Private keys, mnemonics, wallets, keystores
*.pem
*.key
*.keystore
*.p12
*.pfx
key/
keys/
keystore/
keystores/
wallets/
*mnemonic*
*seed-phrase*
*private-key*
*privatekey*
secrets/
.secret
.secrets

# Cloud / API credentials
.aws/
credentials.json
service-account*.json
.wrangler/
.dev.vars

# Bead photos never touch git (EXIF = location leak) — all image formats banned
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.heic
*.heif
*.avif
*.raw
*.dng

# ---------------------------------------------------------------------------
# Node / web tooling (stack not final; extend when the service is built)
# ---------------------------------------------------------------------------
node_modules/
dist/
build/
.output/
.cache/
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
