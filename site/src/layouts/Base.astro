---
import "../styles/tokens.css";
const { title = "The Bead Reserve" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main style="max-width:720px;margin:0 auto;padding:clamp(16px,4vw,48px)">
      <slot />
      <footer style="margin-top:48px;border-top:1px solid var(--hairline);padding-top:16px">
        <a href="/whitepaper.pdf" class="mono">Read the whitepaper</a>
      </footer>
    </main>
  </body>
</html>
