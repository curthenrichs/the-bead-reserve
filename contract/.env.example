# Beadz ops config — copy to .env (gitignored; *.env rule) and fill in.
# Sourced by shell: keep values shell-safe, quote lists.

# Chain endpoint. Local Anvil below; Base Sepolia: https://sepolia.base.org
BEADZ_RPC_URL=http://127.0.0.1:8545
# Mainnet tripwire: scripts refuse chain 8453 unless BEADZ_ALLOW_MAINNET=1
# Etherscan v2 API key for source verification (blank = skip verify)
ETHERSCAN_API_KEY=

# Keystore config (script/wallets.sh). Keystores live in ~/.foundry/keystores
# as $BEADZ_ACCOUNT_PREFIX-<role>; the password file is auto-generated by
# `wallets.sh create` if missing (chmod 600) — back its contents up.
BEADZ_ACCOUNT_PREFIX=beadz-sepolia
BEADZ_WALLETS="deployer keeper keeper2 treasury tester1 tester2"
KEYSTORE_PASSWORD_FILE=~/.foundry/beadz-testnet.pw

# Constructor params for script/Deploy.s.sol (addresses from `wallets.sh status`)
BEADZ_KEEPER=
BEADZ_TREASURY=
BEADZ_AIRDROP_BEADS=0

# Deployed contract address — written by `deploy.sh --broadcast`
BEADZ_ADDRESS=
