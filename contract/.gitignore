# ---------------------------------------------------------------------------
# Privacy boundary (duplicated in every subproject .gitignore on purpose;
# the root .gitignore carries the same net — belt and suspenders)
# ---------------------------------------------------------------------------
# Environment / config — ALL env files ignored; only *.example templates tracked
# (RPC URLs, API keys, and deployer keys live in env files — never in git)
*.env
*.env.*
!*.env.example
*.local

# Private keys, mnemonics, wallets, keystores — no key material of any kind
*.pem
*.key
*.keystore
*.p12
*.pfx
*.pw
key/
keys/
keystore/
keystores/
wallets/
*mnemonic*
*seed-phrase*
*private-key*
*privatekey*
secrets/
.secret
.secrets
.foundry/

# Cloud / API credentials
.aws/
credentials.json
service-account*.json

# Bead photos never touch git (EXIF = location leak) — all image formats banned
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.heic
*.heif
*.avif
*.raw
*.dng

# ---------------------------------------------------------------------------
# Foundry
# NOTE: lib/ is NOT ignored — forge-std and openzeppelin-contracts are
# tracked as git submodules.
# ---------------------------------------------------------------------------
cache/
out/
foundry.lock

# Deployment broadcast logs: raw tx records (deployer address, RPC metadata).
# Publish a deployment record deliberately in docs, never by default.
broadcast/

# Coverage
lcov.info
coverage/

# ---------------------------------------------------------------------------
# Static analysis / fuzzing artifacts (Slither, Echidna, Medusa)
# ---------------------------------------------------------------------------
crytic-export/
slither.db.json
slither-report*
corpus/
echidna-corpus/
medusa-corpus/

# ---------------------------------------------------------------------------
# Defensive: Hardhat/Node-style output (this is a Foundry project; if any
# JS tooling ever appears, its output stays out of git)
# ---------------------------------------------------------------------------
node_modules/
artifacts/
typechain/
typechain-types/
deployments/

# Logs
*.log
