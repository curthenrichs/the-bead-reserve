# ---------------------------------------------------------------------------
# Device-side pipeline config (TEMPLATE) — copy to device.env and fill in.
# device.env is gitignored; this template documents keys only, no secrets.
# ---------------------------------------------------------------------------

# Backend ingest endpoint (subsystem B)
INGEST_URL=https://example.workers.dev/api/ingest

# Shared secret authenticating pushes to /api/ingest (device <-> backend only)
HMAC_SECRET=

# V4L2 device for the USB webcam
CAMERA_DEVICE=/dev/video0

# Tight crop inside the box, pixels: x,y,w,h
CROP_RECT=0,0,1280,720

# Pipeline state root (queue/, archive/, counter, status.json)
STATE_DIR=/var/lib/beadz-camera

# Ed25519 signing key (private; generated on-device via `beadz-camera keygen`)
ED25519_KEY_PATH=/var/lib/beadz-camera/keys/ed25519.key

# Max frames pushed per push-drain run
DRAIN_BATCH_MAX=20
