# ---------------------------------------------------------------------------
# Device-side pipeline config (TEMPLATE) — copy to device.env and fill in.
# device.env is gitignored; this template documents keys only, no secrets.
# ---------------------------------------------------------------------------

# Backend ingest endpoint (subsystem B)
INGEST_URL=https://example.workers.dev/api/ingest

# Shared secret authenticating pushes to /api/ingest (device <-> backend only)
HMAC_SECRET=

# V4L2 device for the USB webcam
CAMERA_DEVICE=/dev/video0

# Capture resolution passed to fswebcam (-r WxH). Omit to use the driver default
# (classically 384x288 — which will FAIL the crop-bounds check against a larger
# CROP_RECT). Set it so capture is deterministic.
CAPTURE_RESOLUTION=1280x720

# Frames to discard before the saved one, so the sensor's auto-exposure/gain
# settle on cold open (fswebcam -S). ~20 adds a few seconds per capture —
# irrelevant at hourly cadence, and it fixes the green/dark first-frame grab.
CAPTURE_SKIP=20

# V4L2 controls applied (via v4l2-ctl) before every capture: name=value,name=value.
# For the sealed LED box, lock a MANUAL white balance and CALIBRATE the temperature
# to your LEDs (capture -> adjust white_balance_temperature -> repeat until a grey
# reference reads neutral). Auto-WB drifts as beads deplete; fixed WB stays constant.
# A bad control name/value makes capture-once fail loud (status last_capture_ok=false).
# Example (uncomment + tune):
# CAMERA_CONTROLS=white_balance_automatic=0,white_balance_temperature=5000,auto_exposure=1

# Tight crop inside the box, pixels: x,y,w,h. MUST fit within CAPTURE_RESOLUTION
# (the bounds check rejects an out-of-frame crop) AND should be tightened to show
# ONLY the jar box — the shipped full-frame value is a placeholder, not opsec-safe.
CROP_RECT=0,0,1280,720

# Pipeline state root (queue/, archive/, counter, status.json)
STATE_DIR=/var/lib/beadz-camera

# Ed25519 signing key (private; generated on-device via `beadz-camera keygen`)
ED25519_KEY_PATH=/var/lib/beadz-camera/keys/ed25519.key

# Max frames pushed per push-drain run
DRAIN_BATCH_MAX=20

# --- Chief Reserve Officer (optional, opt-in) ---
# CRO_IMPL=null is the default: no inference, croText stays absent (today's behavior).
# Set smolvlm ONLY after running the CRO provisioning step (see camera/README.md).
CRO_IMPL=null
# CRO_SERVER_BIN=/opt/llama.cpp/build/bin/llama-server
# CRO_MODEL_PATH=/opt/beadz-cro/SmolVLM-500M-Instruct-Q8_0.gguf
# CRO_MMPROJ_PATH=/opt/beadz-cro/mmproj-SmolVLM-500M-Instruct-Q8_0.gguf
# CRO_CTX_SIZE=2048       # context cap (RAM headroom); validate in the LAN test
# CRO_BEST_OF=3           # flavor attempts, first clean wins
# CRO_MOOD_HOLD_HOURS=3   # mood phase length
# CRO_TIMEOUT_S=180       # inference/health abort guard
