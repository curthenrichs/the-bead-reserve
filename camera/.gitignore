# ---------------------------------------------------------------------------
# Privacy boundary (duplicated in every subproject .gitignore on purpose;
# the root .gitignore carries the same net — belt and suspenders)
# ---------------------------------------------------------------------------
# Environment / config — ALL env files ignored; only *.example templates tracked
*.env
*.env.*
!*.env.example
*.local

# Private keys, mnemonics, wallets, keystores
*.pem
*.key
*.keystore
*.p12
*.pfx
key/
keys/
keystore/
keystores/
wallets/
*mnemonic*
*seed-phrase*
*private-key*
secrets/
.secret
.secrets

# Cloud / API credentials
.aws/
credentials.json
service-account*.json

# Bead photos never touch git (EXIF = location leak) — all image formats banned
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.heic
*.heif
*.avif
*.raw
*.dng

# ---------------------------------------------------------------------------
# Camera pipeline state (prod lives under STATE_DIR=/var/lib/beadz-camera;
# never allow a local state root to be committed)
# ---------------------------------------------------------------------------
queue/
archive/
counter
status.json
*.sig

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-wheel-metadata/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# Cython debug symbols
cython_debug/

# Logs
*.log
