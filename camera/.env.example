# ---------------------------------------------------------------------------
# Pi camera — SSH credentials (TEMPLATE)
# ---------------------------------------------------------------------------
# Copy this file to `.env` in the same directory and fill in real values:
#     cp camera/.env.example camera/.env
#
# `camera/.env` is gitignored — it never gets committed. This `.example`
# file is tracked and documents the expected keys only (no real secrets).
#
# Opsec: keep creds out of git entirely.
# ---------------------------------------------------------------------------

# IP address or hostname of the Pi camera on the LAN, e.g. 192.168.1.42
CAMERA_HOST=

# SSH username, e.g. pi
CAMERA_USER=

# SSH password
CAMERA_PASSWORD=

# SSH port (optional; default 22)
CAMERA_SSH_PORT=22
